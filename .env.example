# 浏览器本地 npm run dev：若要调用线上 /api，可任选其一（不要提交敏感信息到公开仓库）
# VITE_API_BASE_URL=https://你的域名
# VITE_AI_GENERATE_URL=https://你的域名
# iOS/Android 打包：务必在 .env.capacitor 中设置 VITE_API_BASE_URL

# 以下为服务端环境变量（勿使用 VITE_ 前缀，勿暴露给浏览器）

# ====== AI 生成 ======
# PIXELBEAD_AI_API_KEY=你的API密钥
# PIXELBEAD_AI_API_BASE=图像生成 HTTP API 根路径
# PIXELBEAD_AI_IMAGE_MODEL=doubao-seedream-4-5-251128

# ====== 用户系统 - MariaDB/MySQL ======
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的数据库密码
DB_NAME=pixelbead

# ====== 超级管理员 ======
# 管理员用户名（请修改）
ADMIN_USERNAME=admin
# 管理员密码（请修改为复杂密码）
ADMIN_PASSWORD=你的复杂密码

# ====== JWT ======
# JWT 密钥（请修改为随机字符串，至少32位）
JWT_SECRET=你的随机字符串
